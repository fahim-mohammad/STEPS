{
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --prefer-offline",
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://steps.vercel.app"
  },
  "functions": {
    "app/api/**": {
      "maxDuration": 30,
      "memory": 512
    },
    "app/api/pdf/**": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "regions": ["bom1"],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
